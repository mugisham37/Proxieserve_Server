# ─────────────────────────────────────────────────────────────────────────────
# ProxiServe Server — Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# .env is listed in .gitignore and must NEVER be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=ProxiServe Server
APP_ENV=development                  # development | staging | production
APP_DEBUG=true                       # set to false in production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Comma-separated list of allowed CORS origins
APP_CORS_ORIGINS=http://localhost:3000
APP_TRUSTED_PROXY_HEADERS=false      # set to true if behind a reverse proxy


# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=proxieserve
POSTGRES_USER=proxieserve
POSTGRES_PASSWORD=change_me          # choose a strong password


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ── JWT & Encryption ──────────────────────────────────────────────────────────
#
# Generate the three JWT secrets with:
#   python -c "import secrets; print(secrets.token_hex(64))"
#
# Generate the Fernet secret with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
JWT_ISSUER=proxiserve-server
JWT_AUDIENCE=proxiserve-web
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret
JWT_PRE_2FA_SECRET=replace_with_64_byte_hex_secret
FERNET_SECRET=replace_with_fernet_generated_key

# Token lifetimes (seconds)
JWT_ACCESS_TTL_SECONDS=900           # 15 minutes
JWT_REFRESH_TTL_SECONDS=86400        # 24 hours
JWT_STAFF_REFRESH_TTL_SECONDS=28800  # 8 hours
JWT_PRE_2FA_TTL_SECONDS=600          # 10 minutes


# ── OTP / Lockout / Trusted Devices ──────────────────────────────────────────
OTP_TTL_SECONDS=300                  # 5 minutes
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=30
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_SECONDS=900           # 15 minutes
TRUSTED_DEVICE_TTL_SECONDS=604800    # 7 days
PASSWORD_RESET_TTL_SECONDS=3600      # 1 hour


# ── Cookies ───────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=                       # leave blank for localhost
COOKIE_SECURE=false                  # set to true in production (HTTPS only)
COOKIE_SAMESITE=lax                  # lax | strict | none


# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# For local development you can use Mailpit: https://mailpit.axllent.org
#   docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
# Then set SMTP_HOST=localhost and SMTP_PORT=1025 (no username/password needed).
#
EMAIL_FROM=noreply@yourdomain.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=                       # leave blank for unauthenticated local relay
SMTP_PASSWORD=                       # leave blank for unauthenticated local relay


# ── SMS ───────────────────────────────────────────────────────────────────────
SMS_PROVIDER=stub                    # stub (no-op) | twilio | vonage
